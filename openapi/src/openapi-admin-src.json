{
    "openapi": "3.0.2",
    "info": {
        "title": "Administration - Data Capture Service API",
        "description": "Manage a questionnaire lifecycle",
        "version": "1.0.0",
        "license": {
            "name": "MIT"
        },
        "contact": {
            "name": "API Support",
            "email": "api@cica.gov.uk"
        }
    },
    "servers": [
        {
            "url": "/api/admin/v1"
        }
    ],
    "security": [
        {
            "bearerAuth": []
        }
    ],
    "tags": [{"name": "Submissions"}],
    "paths": {
        "/resubmit-failed-applications": {
            "post": {
                "tags": ["Submissions"],
                "summary": "Restart failed submissions",
                "description": "Restart the submission of a failed questionnaire",
                "operationId": "ResubmitQuestionnaire",
                "x-scopes": ["update:questionnaires"],
                "x-requests": {
                    "400": {
                        "requestBody": {
                            "content": {
                                "application/vnd.api+json": {
                                    "example": {
                                        "data": {
                                            "THIS-IS-NOT-A-VALID-PROPERTY-NAME": "submissions",
                                            "attributes": {}
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "auth": false
                    },
                    "403": {
                        "x-scopes": ["create:dummy-resource"]
                    }
                },
                "requestBody": {
                    "description": "Resubmission",
                    "required": true,
                    "content": {
                        "application/vnd.api+json": {
                            "schema": {
                                "$ref": "./json-schemas/admin/resubmit-failed-submissions/post/req/200.json"
                            },
                            "example": {
                                "data": {
                                    "type": "resubmissions",
                                    "attributes": {}
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Resubmitted",
                        "content": {
                            "application/vnd.api+json": {
                                "schema": {
                                    "$ref": "./json-schemas/admin/resubmit-failed-submissions/post/res/200.json"
                                },
                                "example": {
                                    "data": {
                                        "id": "c478f63c-e074-4c36-ad22-cebb19819fe7",
                                        "type": "resubmissions",
                                        "attributes": {
                                            "resubmissions": [
                                                {
                                                    "questionnaireId": "285cb104-0c15-4a9c-9840-cb1007f098fb",
                                                    "submitted": false,
                                                    "status": "IN_PROGRESS",
                                                    "caseReferenceNumber": "11\\111111"
                                                }
                                            ]
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "$ref": "#/components/responses/BadRequest"
                    },
                    "401": {
                        "$ref": "#/components/responses/UnauthorizedError"
                    },
                    "403": {
                        "$ref": "#/components/responses/Forbidden"
                    },
                    "404": {
                        "$ref": "#/components/responses/NotFound"
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        },
        "parameters": {
            "questionnaireId": {
                "name": "questionnaireId",
                "in": "path",
                "required": true,
                "description": "The id of the specific questionnaire instance. Format UUIDv4.",
                "schema": {
                    "$ref": "./json-schemas/parameters/questionnaireId.json"
                },
                "example": "285cb104-0c15-4a9c-9840-cb1007f098fb"
            }
        },
        "responses": {
            "BadRequest": {
                "description": "There is an issue with the request",
                "content": {
                    "application/vnd.api+json": {
                        "schema": {
                            "$ref": "./json-schemas/responses/400.json"
                        },
                        "example": {
                            "errors": [
                                {
                                    "status": 400,
                                    "title": "400 Bad Request",
                                    "detail": "Request JSON is malformed"
                                }
                            ]
                        }
                    }
                }
            },
            "UnauthorizedError": {
                "description": "Access token is missing or invalid",
                "content": {
                    "application/vnd.api+json": {
                        "schema": {
                            "$ref": "./json-schemas/responses/401.json"
                        },
                        "example": {
                            "errors": [
                                {
                                    "status": 401,
                                    "detail": "No authorization token was found"
                                }
                            ]
                        }
                    }
                }
            },
            "Forbidden": {
                "description": "The JWT doesn't permit access to this endpoint",
                "content": {
                    "application/vnd.api+json": {
                        "schema": {
                            "$ref": "./json-schemas/responses/403.json"
                        },
                        "example": {
                            "errors": [
                                {
                                    "status": 403,
                                    "title": "403 Forbidden",
                                    "detail": "Insufficient scope"
                                }
                            ]
                        }
                    }
                }
            },
            "NotFound": {
                "description": "The specified resource was not found",
                "content": {
                    "application/vnd.api+json": {
                        "schema": {
                            "$ref": "./json-schemas/responses/404.json"
                        },
                        "example": {
                            "errors": [
                                {
                                    "status": 404,
                                    "title": "404 Not Found",
                                    "detail": "Resource /api/v1/questionnaires/2d7caf89-2c72-469f-b19d-17f2a22270b6/sections/answers does not exist"
                                }
                            ]
                        }
                    }
                }
            },
            "Conflict": {
                "description": "Conflict",
                "content": {
                    "application/vnd.api+json": {
                        "schema": {
                            "$ref": "./json-schemas/responses/409.json"
                        },
                        "example": {
                            "errors": [
                                {
                                    "status": 409,
                                    "title": "409 conflict",
                                    "detail": "Endpoint /api/v1/questionnaires/68653be7-877f-4106-b91e-4ba8dac883f3/sections/system/answers accepts only resources of type \"answers\""
                                }
                            ]
                        }
                    }
                }
            }
        }
    }
}
